# =============================================================================
# Django E-commerce Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# Core Django Settings
# =============================================================================

# SECURITY WARNING: keep the secret key used in production secret!
# Generate a new key with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here-change-in-production

# Debug mode - NEVER enable in production
DEBUG=False

# Allowed hosts - comma-separated list
# Example: localhost,127.0.0.1,.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================

# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
# For Docker Compose
DATABASE_URL=postgres://postgres:postgres@db:5432/django_ecommerce
# In Docker, DB_HOST should be the service name (e.g., db)

# Connection pool max age (seconds)
DB_CONN_MAX_AGE=600

# Or use individual settings:
# DB_NAME=django_ecommerce
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# =============================================================================
# Redis Configuration (Caching & Celery)
# =============================================================================

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# =============================================================================
# Email Configuration (SMTP)
# =============================================================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# For development, use console backend:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# =============================================================================
# Stripe Payment Configuration
# =============================================================================

# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook secret from Stripe CLI or Dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# AWS S3 Configuration (Optional - for media file storage)
# =============================================================================

# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com

# =============================================================================
# Security Settings (Production)
# =============================================================================

# Enable HTTPS redirect
SECURE_SSL_REDIRECT=True

# Health check token for load balancers
HEALTH_CHECK_TOKEN=your-health-check-token

# =============================================================================
# Sentry Configuration (Optional - for error tracking)
# =============================================================================

# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# E-commerce Settings
# =============================================================================

# Free shipping threshold
FREE_SHIPPING_THRESHOLD=100.00

# Flat shipping rate
FLAT_SHIPPING_RATE=9.99

# Default currency
DEFAULT_CURRENCY=USD

# =============================================================================
# Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
